# ============================================
# E-COMMERCE PLATFORM - ENVIRONMENT VARIABLES
# ============================================

# ===== DATABASE =====
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce_db
HIBERNATE_DDL=update

# ===== PGADMIN =====
PGADMIN_EMAIL=admin@ecommerce.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ===== BACKEND =====
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
VITE_API_URL=http://localhost:8080/api
JWT_SECRET=your-secret-key-min-32-chars-required-for-production-use-a-real-secret
JWT_EXPIRATION=86400000

# ===== FRONTEND =====
FRONTEND_HOST_PORT=80
VITE_API_URL=http://localhost:8080/api
VITE_APP_TITLE=NexCart

# ===== DOCKER REGISTRY =====
# For CI/CD: push Docker images to registry
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your-github-username
DOCKER_PASSWORD=your-github-token

# ===== NODE ENVIRONMENT =====
NODE_ENV=development

# ===== LOG LEVEL =====
LOG_LEVEL=debug

# ===== JAVA OPTIONS =====
JAVA_OPTS=-Xmx512m -Xms256m
