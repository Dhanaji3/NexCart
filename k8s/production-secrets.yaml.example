## Example production secrets file. DO NOT commit real secrets.
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: ecommerce
type: Opaque
stringData:
  JWT_SECRET: "<REPLACE_WITH_STRONG_SECRET>"
  DB_PASSWORD: "<REPLACE_WITH_DB_PASSWORD>"
  PGADMIN_PASSWORD: "<REPLACE_WITH_PGADMIN_PASSWORD>"

  # Optional: AWS S3 credentials for offsite backups
  AWS_ACCESS_KEY_ID: "<REPLACE_WITH_AWS_ACCESS_KEY_ID>"
  AWS_SECRET_ACCESS_KEY: "<REPLACE_WITH_AWS_SECRET_ACCESS_KEY>"
  S3_BUCKET: "<REPLACE_WITH_S3_BUCKET_NAME>"

---
# Postgres secret
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: ecommerce
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: "<REPLACE_WITH_DB_PASSWORD>"
  POSTGRES_DB: ecommerce_db
